# ===========================================
# Production environment variables
# Copy this file to docker/.env and fill in values
# ===========================================

# PostgreSQL password (use a strong random password)
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=

# JWT Secrets (use different random strings for each)
# Generate: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Server URLs (replace YOUR_SERVER_IP with actual IP)
CORS_ORIGIN=http://YOUR_SERVER_IP
BASE_URL=http://YOUR_SERVER_IP
