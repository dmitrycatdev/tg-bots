{
  "name": "tg-bots",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:migrate": "yarn workspace @tg-bots/api prisma migrate dev",
    "db:generate": "yarn workspace @tg-bots/api prisma generate",
    "db:seed": "yarn workspace @tg-bots/api prisma db seed",
    "db:studio": "yarn workspace @tg-bots/api prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@1.22.22"
}
